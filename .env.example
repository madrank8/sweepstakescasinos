# Reader-reports (Supabase) — SERVER-ONLY secrets. Never commit real values.
# Set these in Vercel → Project → Settings → Environment Variables, and in a
# local .env for `npm run dev`.

# Supabase project (reusing the "sweepdogs-site" project).
SUPABASE_URL=https://ybedkkpunwrtthvffcra.supabase.co

# Service-role key: Supabase dashboard → Project Settings → API → service_role.
# This bypasses RLS — keep it server-only, never prefix with PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional salt used to hash submitter IPs for rate limiting.
READER_REPORTS_SALT=

# ---------------------------------------------------------------------------
# Sweepstakes Legality Tracker (read-only) — points at the EXISTING SweepDogs
# tracker Supabase project, kept fresh by the daily n8n pipeline. Uses the
# public ANON key only (never writes). Needed at BUILD time (prerendered state
# pages + /state-legality/) AND at RUNTIME (SSR hub + API endpoints). If unset,
# the site falls back to the committed baseline in src/lib/tracker/fallback.ts.
TRACKER_SUPABASE_URL=
TRACKER_SUPABASE_ANON_KEY=

# Freshness: the n8n workflow POSTs a Vercel Deploy Hook for THIS project after
# each daily ingest so prerendered pages rebuild. Create it in Vercel → Project
# → Settings → Git → Deploy Hooks, then paste the URL into the n8n workflow
# (NOT into the app). Kept here for reference only.
# WIZ_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
