# Reader-reports (Supabase) — SERVER-ONLY secrets. Never commit real values.
# Set these in Vercel → Project → Settings → Environment Variables, and in a
# local .env for `npm run dev`.

# Supabase project (reusing the "sweepdogs-site" project).
SUPABASE_URL=https://ybedkkpunwrtthvffcra.supabase.co

# Service-role key: Supabase dashboard → Project Settings → API → service_role.
# This bypasses RLS — keep it server-only, never prefix with PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional salt used to hash submitter IPs for rate limiting.
READER_REPORTS_SALT=
