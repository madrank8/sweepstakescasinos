{
  "name": "sweepstakes-casinos-list-astro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "verify:availability": "tsx scripts/verify-availability.ts",
    "map:generate": "node scripts/generate-us-map.mjs",
    "generate:pages": "tsx scripts/generate-astro-pages.mjs",
    "astro:dev": "npm run generate:pages && ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "dev": "npm run build && ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "tracker:lint": "tsx scripts/lint-tracker-purity.ts",
    "prebuild": "npm run content:lint && npm run tracker:lint && npm run schema:verify && npm run methodology:check && npm run reader-reports:aggregate && npm run generate:pages",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "testing:scaffold": "node scripts/testing-scaffold.mjs",
    "testing:verify": "tsx scripts/verify-testing-evidence.ts",
    "testing:verify-overclaims": "tsx scripts/verify-overclaims.ts",
    "testing:status": "tsx scripts/verify-testing-evidence.ts --status-only",
    "testing:apply": "tsx scripts/apply-testing-results.ts",
    "testing:anchors": "tsx scripts/add-testing-anchors.ts",
    "content:lint": "tsx scripts/lint-experience-claims.ts",
    "schema:verify": "tsx scripts/verify-schema.ts && tsx scripts/verify-schema-helpers.ts",
    "methodology:check": "tsx scripts/verify-methodology-consistency.ts",
    "reader-reports:aggregate": "tsx scripts/aggregate-reader-reports.ts",
    "seo:extract": "python3 scripts/seo/extract_guides.py",
    "seo:fingerprint": "python3 scripts/seo/corpus_fingerprint.py --in .seo/pages.json --min-cluster 2",
    "seo:provenance": "python3 scripts/seo/r45_provenance.py --in .seo/pages.json",
    "seo:score": "npm run build && npm run seo:extract && npm run seo:fingerprint && npm run seo:provenance",
    "ci": "npm run verify:availability && npm run content:lint && npm run tracker:lint && npm run methodology:check && npm run testing:verify && npm run testing:verify-overclaims && npm run build"
  },
  "devDependencies": {
    "astro": "^7.0.0",
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0",
    "tsx": "^4.22.4",
    "us-atlas": "^3.0.1"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/vercel": "^11.0.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vercel/analytics": "^2.0.1"
  }
}
