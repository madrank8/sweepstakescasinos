---
/**
 * News article pages (MDX `news` collection -> /news/<slug>/).
 * NewsArticle JSON-LD + optional FAQPage for AEO/PAA extraction.
 */
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { AUTHOR_ID } from '../../lib/schema';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('news', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const ORIGIN = 'https://sweepstakeswiz.com';
const canonicalPath = `/news/${entry.id}/`;
const canonical = `${ORIGIN}${canonicalPath}`;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'News', path: '/news/' },
  { name: entry.data.title, path: canonicalPath },
];

const faq = entry.data.faq ?? [];
const faqLd =
  faq.length > 0
    ? {
        '@type': 'FAQPage',
        '@id': `${canonical}#faq`,
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : undefined;

const publishedIso = entry.data.published.toISOString();
const updatedIso = (entry.data.updated ?? entry.data.published).toISOString();

const newsLd = {
  '@type': 'NewsArticle',
  '@id': `${canonical}#article`,
  headline: entry.data.title,
  description: entry.data.description,
  url: canonical,
  mainEntityOfPage: { '@id': `${canonical}#webpage` },
  inLanguage: 'en-US',
  datePublished: publishedIso,
  dateModified: updatedIso,
  author: { '@id': AUTHOR_ID },
  publisher: { '@id': `${ORIGIN}/#organization` },
  ...(entry.data.sourceUrl ? { citation: entry.data.sourceUrl } : {}),
  ...(entry.data.citations.length > 0 ? { mentions: entry.data.citations.map((u) => ({ '@type': 'WebPage', url: u })) } : {}),
};

const jsonLd = faqLd ? [newsLd, faqLd] : [newsLd];
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  pageType="WebPage"
  datePublished={publishedIso}
  dateModified={updatedIso}
  mainEntityId={`${canonical}#article`}
  jsonLd={jsonLd}
>
  <article class="news-article prose">
    <p class="news-kicker">
      {entry.data.category === 'legislation' && 'Legislation'}
      {entry.data.category === 'shutdown' && 'Operator shutdown'}
      {entry.data.category === 'enforcement' && 'Enforcement'}
      {entry.data.category === 'industry' && 'Industry'}
      {entry.data.stateCode ? ` · ${entry.data.stateCode}` : ''}
      · Updated{' '}
      <time datetime={updatedIso.slice(0, 10)}>
        {new Date(updatedIso).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          timeZone: 'UTC',
        })}
      </time>
    </p>
    <Content />
    {faq.length > 0 && (
      <section class="news-faq">
        <h2>Frequently asked questions</h2>
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    )}
  </article>
</ContentLayout>

<style>
  .news-kicker {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #64748b;
    margin: 0 0 1.25rem;
  }
  .news-article :global(p) { line-height: 1.72; margin-bottom: 1rem; }
  .news-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.25rem;
    font-size: 0.9rem;
  }
  .news-article :global(th),
  .news-article :global(td) {
    border: 1px solid rgba(15, 23, 42, 0.1);
    padding: 0.5rem 0.65rem;
    text-align: left;
  }
  .news-article :global(th) { background: #f8fafc; }
  .news-article :global(blockquote) {
    border-left: 4px solid #6366f1;
    margin: 1.25rem 0;
    padding: 0.5rem 0 0.5rem 1rem;
    color: #475569;
    font-size: 0.92rem;
  }
  .news-faq { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(15, 23, 42, 0.08); }
  .news-faq h2 { font-size: 1.2rem; margin-bottom: 1rem; }
  .news-faq details {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 10px;
    padding: 0.65rem 0.85rem;
    margin-bottom: 0.5rem;
  }
  .news-faq summary { font-weight: 700; cursor: pointer; }
  .news-faq p { margin: 0.5rem 0 0; font-size: 0.92rem; line-height: 1.65; color: #475569; }
</style>
