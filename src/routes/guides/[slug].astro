---
/**
 * Educational guide / pillar pages (MDX `guides` collection -> /guides/<slug>/).
 * Prerendered. Emits an Article content layer (image, ISO dates, wordCount,
 * about/mentions, citation, author/publisher as @id refs) + optional FAQPage
 * and HowTo nodes, all merged into the layout's consolidated @graph.
 * Authored in src/routes; copied into src/pages by the generator.
 */
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { ORG_ID, AUTHOR_ID } from '../../lib/schema';
import { imageDimensions } from '../../lib/svgDimensions';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('guides', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const ORIGIN = 'https://sweepstakeswiz.com';
const canonicalPath = `/guides/${entry.id}/`;
const canonical = `${ORIGIN}${canonicalPath}`;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Guides', path: '/guides/' },
  { name: entry.data.title, path: canonicalPath },
];

const faq = entry.data.faq ?? [];
const faqLd =
  faq.length > 0
    ? {
        '@type': 'FAQPage',
        '@id': `${canonical}#faq`,
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : undefined;

const toIso = (d: unknown) => (d instanceof Date ? d.toISOString() : undefined);
const publishedIso = toIso(entry.data.published) ?? toIso(entry.data.updated);
const updatedIso = toIso(entry.data.updated) ?? publishedIso;

// wordCount from the raw MDX body (strip frontmatter already removed; strip
// markup/code so the count approximates the rendered prose).
const wordCount = entry.body
  ? entry.body
      .replace(/<[^>]+>/g, ' ')
      .replace(/[#*_`>|-]+/g, ' ')
      .split(/\s+/)
      .filter(Boolean).length
  : undefined;

// Hero image dimensions are read from the file bytes at build time so we
// never lie in JSON-LD — SVGs use viewBox / width+height, PNGs use IHDR.
// Legacy 1376x768 remains as the last-resort fallback for PNGs that predate
// the reader (kept intentionally small; new content should always resolve).
const heroDims = entry.data.image ? await imageDimensions(entry.data.image) : null;
const image = entry.data.image
  ? {
      '@type': 'ImageObject',
      url: `${ORIGIN}${entry.data.image}`,
      ...(heroDims ?? { width: 1376, height: 768 }),
    }
  : undefined;
const citations = entry.data.citations ?? [];

// Inline figures declared in MDX frontmatter -> one ImageObject per figure.
// Dimensions are resolved from the file first; frontmatter-declared dims are
// the fallback. Each figure gets a stable @id so it can be linked from the
// Article body and referenced by external consumers.
const rawFigures = entry.data.figures ?? [];
const figureNodes = await Promise.all(
  rawFigures.map(async (f, i) => {
    const dims = (await imageDimensions(f.src)) ?? {
      width: f.width ?? 960,
      height: f.height ?? 540,
    };
    return {
      '@type': 'ImageObject',
      '@id': `${canonical}#figure-${f.id ?? i + 1}`,
      contentUrl: f.src.startsWith('http') ? f.src : `${ORIGIN}${f.src}`,
      url: f.src.startsWith('http') ? f.src : `${ORIGIN}${f.src}`,
      width: dims.width,
      height: dims.height,
      description: f.alt,
      ...(f.caption ? { caption: f.caption } : {}),
      creator: { '@id': ORG_ID },
      creditText: 'SweepstakesWiz',
      isPartOf: { '@id': `${canonical}#article` },
    };
  }),
);

// Article: the page's content entity. Author/publisher are @id refs — the
// full Person node is auto-appended to the on-page graph by buildPageGraph.
// `about` = macro-context entity; Wikidata Q-ids intentionally deferred until
// verified (plan §6 open item 1) — never guess Q-ids.
const articleLd = {
  '@type': 'Article',
  '@id': `${canonical}#article`,
  headline: entry.data.title,
  description: entry.data.description,
  mainEntityOfPage: { '@id': `${canonical}#webpage` },
  url: canonical,
  inLanguage: 'en-US',
  ...(image ? { image } : {}),
  ...(publishedIso ? { datePublished: publishedIso } : {}),
  ...(updatedIso ? { dateModified: updatedIso } : {}),
  ...(wordCount ? { wordCount } : {}),
  about: {
    '@type': 'Thing',
    name: 'Sweepstakes casino',
    description:
      'Online social casino model where players use Gold Coins for entertainment and promotional Sweeps Coins redeemable for prizes under US sweepstakes law.',
  },
  mentions: [
    { '@type': 'Thing', name: 'Sweepstake', sameAs: 'https://en.wikipedia.org/wiki/Sweepstake' },
  ],
  ...(citations.length > 0
    ? { citation: citations.map((url) => ({ '@type': 'CreativeWork', url })) }
    : {}),
  author: { '@id': AUTHOR_ID },
  publisher: { '@id': ORG_ID },
};

// HowTo for procedural guides — steps must mirror the visible step list.
const howTo = entry.data.howTo;
const howToLd = howTo
  ? {
      '@type': 'HowTo',
      '@id': `${canonical}#howto`,
      name: howTo.name,
      step: howTo.steps.map((s, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.name,
        text: s.text,
      })),
    }
  : undefined;

// ItemList for guides that enumerate items (e.g. a categorized casino list).
// Items mirror a visible list in the body; url is normalized to absolute.
const itemList = entry.data.itemList;
const itemListLd = itemList
  ? {
      '@type': 'ItemList',
      '@id': `${canonical}#itemlist`,
      name: itemList.name,
      numberOfItems: itemList.items.length,
      itemListElement: itemList.items.map((it, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: it.name,
        url: it.url.startsWith('http') ? it.url : `${ORIGIN}${it.url}`,
      })),
    }
  : undefined;

const jsonLd = [
  articleLd,
  ...(faqLd ? [faqLd] : []),
  ...(howToLd ? [howToLd] : []),
  ...(itemListLd ? [itemListLd] : []),
  ...figureNodes,
];
---
<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  heroTitle={entry.data.heroTitle}
  heroSubtitle={entry.data.description}
  ogImage={entry.data.image}
  datePublished={publishedIso}
  dateModified={updatedIso}
  mainEntityId={`${canonical}#article`}
  jsonLd={jsonLd}
>
  <Content />

  {faq.length > 0 && (
    <section aria-label="Frequently asked questions">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <>
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </>
      ))}
    </section>
  )}
</ContentLayout>
