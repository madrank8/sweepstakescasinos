---
/**
 * Educational guide / pillar pages (MDX `guides` collection -> /guides/<slug>/).
 * Prerendered. Optional FAQ renders as a visible section + FAQPage JSON-LD.
 * Authored in src/routes; copied into src/pages by the generator.
 */
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('guides', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const canonicalPath = `/guides/${entry.id}/`;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Guides', path: '/guides/' },
  { name: entry.data.title, path: canonicalPath },
];

const faq = entry.data.faq ?? [];
const faqLd =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : undefined;

const ORIGIN = 'https://sweepstakeswiz.com';
const updatedIso =
  entry.data.updated instanceof Date ? entry.data.updated.toISOString().slice(0, 10) : undefined;

// Article + named author (Person) for E-E-A-T — the human accountable for the page.
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  mainEntityOfPage: `${ORIGIN}${canonicalPath}`,
  author: {
    '@type': 'Person',
    '@id': `${ORIGIN}/author/ilija-milosevic/#person`,
    name: 'Ilija Milosevic',
    url: `${ORIGIN}/author/ilija-milosevic/`,
    jobTitle: 'iGaming Writer & Analyst',
    sameAs: ['https://www.linkedin.com/in/ilija-milosevic-hiperion'],
  },
  publisher: { '@type': 'Organization', name: 'Sweepstakes Wiz', url: `${ORIGIN}/` },
  ...(updatedIso ? { dateModified: updatedIso } : {}),
};

const jsonLd = [articleLd, ...(faqLd ? [faqLd] : [])];
---
<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  heroTitle={entry.data.heroTitle}
  heroSubtitle={entry.data.description}
  jsonLd={jsonLd}
>
  <Content />

  {faq.length > 0 && (
    <section aria-label="Frequently asked questions">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <>
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </>
      ))}
    </section>
  )}
</ContentLayout>
