---
/**
 * State legality pages (MDX content collection -> /states/<code>/).
 * Prerendered static pages. Partner availability is shown as EDITORIAL links to
 * reviews (no affiliate CTAs here); actual affiliate clicks always go through
 * the geo-gated /bonuses/ gateway, which suppresses by the visitor's state.
 *
 * Authored in src/routes and copied into src/pages by the page generator so it
 * survives the generator's wipe of src/pages.
 */
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { AFFILIATE_PARTNERS } from '../../data/affiliates';
import { isPartnerAvailableInState, isStateBannedSitewide } from '../../data/geo';
import { stateName, type UsStateCode } from '../../data/usStates';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('states', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const ORIGIN = 'https://sweepstakeswiz.com';

const code = entry.data.stateCode as UsStateCode;
const name = stateName(code);
const banned = isStateBannedSitewide(code);
const availablePartners = banned
  ? []
  : AFFILIATE_PARTNERS.filter((p) => isPartnerAvailableInState(p, code));

const canonicalPath = `/states/${entry.id}/`;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'State Legality', path: '/state-legality/' },
  { name: name, path: canonicalPath },
];

const faq = entry.data.faq ?? [];
const faqLd =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : undefined;

// E-E-A-T: named author + visible "last updated" + WebPage dateModified schema.
const updatedDate = entry.data.updated instanceof Date ? entry.data.updated : undefined;
const updatedIso = updatedDate ? updatedDate.toISOString().slice(0, 10) : undefined;
const updatedHuman = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
  : undefined;

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: entry.data.title,
  description: entry.data.description,
  url: `${ORIGIN}${canonicalPath}`,
  ...(updatedIso ? { datePublished: updatedIso, dateModified: updatedIso } : {}),
  isPartOf: { '@type': 'WebSite', name: 'Sweepstakes Wiz', url: `${ORIGIN}/` },
  about: { '@type': 'Thing', name: `Sweepstakes casino legality in ${name}` },
  author: {
    '@type': 'Person',
    '@id': `${ORIGIN}/author/ilija-milosevic/#person`,
    name: 'Ilija Milosevic',
    url: `${ORIGIN}/author/ilija-milosevic/`,
    jobTitle: 'iGaming Writer & Analyst',
  },
  publisher: { '@type': 'Organization', name: 'Sweepstakes Wiz', url: `${ORIGIN}/` },
};
const jsonLd = faqLd ? [webPageLd, faqLd] : [webPageLd];

// Auto sibling cross-links so every state page interlinks the state cluster.
const allStates = await getCollection('states', (e) => !e.data.draft);
const siblings = allStates
  .filter((e) => e.id !== entry.id)
  .map((e) => ({
    slug: e.id,
    name: stateName(e.data.stateCode as UsStateCode),
    status: e.data.legalStatus as string,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---
<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  heroSubtitle={entry.data.description}
  jsonLd={jsonLd}
>
  <div class="state-flag-bar">
    <img
      class="state-flag"
      src={`/images/states/${code.toLowerCase()}.png`}
      alt={`${name} state flag`}
      loading="eager"
    />
    <span>{name}</span>
  </div>

  <Content />

  <h2>Available sweepstakes casinos in {name}</h2>
  {banned ? (
    <div class="notice-box">
      <p>
        Because of {name}&rsquo;s rules on marketing sweepstakes casinos, we show
        informational content only here and do not promote affiliate offers.
        Please review the law and each operator&rsquo;s official rules before
        playing.
      </p>
    </div>
  ) : availablePartners.length > 0 ? (
    <ul>
      {availablePartners.map((p) => (
        <li>
          <a href={`/reviews/${p.slug}/`}>{p.name} review</a>
          {p.model === 'cpa' ? '' : ''}
        </li>
      ))}
    </ul>
  ) : (
    <p>No reviewed operators currently list availability in {name}.</p>
  )}

  {faq.length > 0 && (
    <section aria-label="Frequently asked questions">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <>
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </>
      ))}
    </section>
  )}

  {siblings.length > 0 && (
    <section class="state-siblings" aria-label="Other state guides">
      <h2>Sweepstakes casino legality in other states</h2>
      <ul>
        {siblings.map((s) => (
          <li>
            <a href={`/states/${s.slug}/`}>Are sweepstakes casinos legal in {s.name}?</a>
            {' '}&mdash; {s.status === 'available' ? 'offers shown' : 'info-only'}
          </li>
        ))}
      </ul>
      <p>See every US state on the <a href="/state-legality/">state legality hub</a>.</p>
    </section>
  )}

  <p class="state-byline">
    Researched and written by <a href="/author/ilija-milosevic/">Ilija Milosevic</a>,
    iGaming Writer &amp; Analyst.{updatedHuman ? ` Last updated ${updatedHuman}.` : ''} This page
    is editorial analysis of public law and operator terms &mdash; not legal advice.
  </p>

  <div class="info-box">
    <p>
      Play responsibly &middot; 21+. Free, confidential help is available 24/7 at
      <a href="tel:18004262537">1-800-GAMBLER</a>. See our
      <a href="/responsible-gaming/">Responsible Gaming</a> page. This page is
      informational and not legal advice.
    </p>
  </div>

  <style>
    .state-flag-bar{display:flex;align-items:center;gap:12px;margin:0 0 20px;}
    .state-flag{height:46px;width:auto;border:1px solid #e2e8f0;border-radius:6px;box-shadow:0 1px 4px rgba(10,22,40,.14);display:block;}
    .state-flag-bar span{font-family:'Sora',sans-serif;font-weight:800;color:#0a1628;font-size:1.1rem;letter-spacing:-0.2px;}
    .state-siblings{margin:8px 0 22px;}
    .state-siblings ul{margin:8px 0 0;padding-left:20px;}
    .state-siblings li{margin:6px 0;line-height:1.55;}
    .state-byline{font-size:0.85rem;color:#64748b;border-top:1px solid #e2e8f0;padding-top:14px;margin:22px 0 18px;}
    .state-byline a{color:#b45309;font-weight:600;}
  </style>
</ContentLayout>
