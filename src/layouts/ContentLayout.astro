---
/**
 * Shared layout for native MDX content pages (state pages, new reviews,
 * comparisons). Renders the SAME global chrome as the rest of the site
 * (nav/footer via partial includes, compliance ribbon, publisher Org schema)
 * plus a per-page BreadcrumbList and optional extra JSON-LD.
 */
import { stampUpdatedDate } from '../lib/htmlStamp';
import { complianceRibbonMarkup, orgSchemaMarkup } from '../lib/pageChrome';

const ORIGIN = 'https://sweepstakeslist.vercel.app';

interface Crumb {
  name: string;
  path: string;
}
interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  breadcrumbs?: Crumb[];
  heroTitle?: string;
  heroSubtitle?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath,
  breadcrumbs = [],
  heroTitle,
  heroSubtitle,
  robots = 'index, follow',
  jsonLd,
} = Astro.props;

const canonical = `${ORIGIN}${canonicalPath}`;
const ribbon = stampUpdatedDate(complianceRibbonMarkup());
const orgScript = orgSchemaMarkup();

const breadcrumbLd =
  breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.name,
          item: `${ORIGIN}${c.path}`,
        })),
      }
    : null;

const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <script src="/partials/include.js" defer></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="/_external/fonts.googleapis.com/css2__qba979b498c" rel="stylesheet" />
    <link rel="stylesheet" href="/partials/trust.css" />
    <Fragment set:html={orgScript} />
    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}
    {extraLd.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
  </head>
  <body>
    <Fragment set:html={ribbon} />
    <div data-include="/partials/nav.html"></div>

    <header class="page-hero">
      <div class="page-hero-inner">
        {breadcrumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            {breadcrumbs.map((c, i) => (
              <>
                {i > 0 && <span class="sep">&#8250;</span>}
                {i < breadcrumbs.length - 1 ? (
                  <a href={c.path}>{c.name}</a>
                ) : (
                  <span aria-current="page">{c.name}</span>
                )}
              </>
            ))}
          </nav>
        )}
        <h1 set:html={heroTitle ?? title}></h1>
        {heroSubtitle && <p class="page-hero-sub">{heroSubtitle}</p>}
      </div>
    </header>

    <main class="content-section">
      <div class="content-card">
        <slot />
      </div>
    </main>

    <div data-include="/partials/footer.html"></div>
  </body>
</html>
