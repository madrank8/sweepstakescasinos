---
/**
 * Shared layout for native MDX content pages (state pages, new reviews,
 * comparisons). Renders the SAME global chrome as the rest of the site
 * (nav/footer via partial includes, compliance ribbon) plus ONE consolidated
 * JSON-LD @graph per page: publisher Organization + WebSite + typed WebPage +
 * BreadcrumbList (foundation) + any content-layer nodes passed via `jsonLd`.
 * See docs/schema-markup-plan.md §3.2 and src/lib/schema.ts.
 */
import { stampUpdatedDate } from '../lib/htmlStamp';
import {
  complianceRibbonMarkup,
  faviconMarkup,
  googleAnalyticsMarkup,
} from '../lib/pageChrome';
import { buildPageGraph, type WebPageType } from '../lib/schema';

const ORIGIN = 'https://sweepstakeswiz.com';

interface Crumb {
  name: string;
  path: string;
}
interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  breadcrumbs?: Crumb[];
  heroTitle?: string;
  heroSubtitle?: string;
  robots?: string;
  /** Absolute-from-root path to a social preview image (og:image / twitter). */
  ogImage?: string;
  /** schema.org WebPage subtype for this page's foundation node. */
  pageType?: WebPageType;
  /** ISO 8601 dates for the WebPage node. */
  datePublished?: string;
  dateModified?: string;
  /** @id of the page's primary content entity (WebPage.mainEntity ref). */
  mainEntityId?: string;
  /** Content-layer JSON-LD nodes, merged into the consolidated @graph. */
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath,
  breadcrumbs = [],
  heroTitle,
  heroSubtitle,
  robots = 'index, follow',
  ogImage,
  pageType = 'WebPage',
  datePublished,
  dateModified,
  mainEntityId,
  jsonLd,
} = Astro.props;

const canonical = `${ORIGIN}${canonicalPath}`;
const ogImageUrl = ogImage ? `${ORIGIN}${ogImage}` : undefined;
const ribbon = stampUpdatedDate(complianceRibbonMarkup());
const googleAnalytics = googleAnalyticsMarkup();

const contentNodes = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const pageGraph = buildPageGraph({
  url: canonical,
  pageType,
  title,
  description,
  breadcrumbs,
  datePublished,
  dateModified,
  mainEntityId,
  nodes: contentNodes,
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <Fragment set:html={faviconMarkup()} />
    <Fragment set:html={googleAnalytics} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    <script src="/partials/include.js" defer></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="/_external/fonts.googleapis.com/css2__qba979b498c" rel="stylesheet" />
    <link rel="stylesheet" href="/partials/trust.css" />
    <script type="application/ld+json" set:html={JSON.stringify(pageGraph)} />
  </head>
  <body>
    <Fragment set:html={ribbon} />
    <div data-include="/partials/nav.html"></div>

    <header class="page-hero">
      <div class="page-hero-inner">
        {breadcrumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            {breadcrumbs.map((c, i) => (
              <>
                {i > 0 && <span class="sep">&#8250;</span>}
                {i < breadcrumbs.length - 1 ? (
                  <a href={c.path}>{c.name}</a>
                ) : (
                  <span aria-current="page">{c.name}</span>
                )}
              </>
            ))}
          </nav>
        )}
        <h1 set:html={heroTitle ?? title}></h1>
        {heroSubtitle && <p class="page-hero-sub">{heroSubtitle}</p>}
      </div>
    </header>

    <main class="content-section">
      <div class="content-card">
        <slot />
      </div>
    </main>

    <div data-include="/partials/footer.html"></div>
  </body>
</html>
