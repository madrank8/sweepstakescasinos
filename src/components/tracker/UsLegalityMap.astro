---
/**
 * Interactive US sweepstakes legality map — zero client-side framework.
 *
 * Server-renders an inline <svg> from the committed, build-time geometry in
 * usStatePaths.ts (generated by scripts/generate-us-map.mjs). Each state path is
 * colored from live tracker status. A tiny vanilla script handles the filter
 * chips and hover tooltip — no React/Preact island, matching the site's
 * no-framework pattern.
 */
import { US_STATE_PATHS } from './usStatePaths';
import { SWEEPS_STATUS_META, type SweepsCasinoStatus } from '../../lib/tracker/types';

export interface MapStateInput {
  state_code: string;
  state_name: string;
  state_slug: string;
  sweeps_casino_status: SweepsCasinoStatus;
  sweeps_status_changed_at: string;
  sweeps_status_summary: string;
}

interface Props {
  states: MapStateInput[];
  /** Base path for per-state links (default the Wiz editorial state pages). */
  linkBase?: string;
}

const { states, linkBase = '/states/' } = Astro.props;

const byCode = new Map(states.map((s) => [s.state_code.toUpperCase(), s]));
const now = Date.now();
const DAY = 86400000;

const FILTERS: Array<{ id: string; label: string }> = [
  { id: 'all', label: 'All' },
  { id: 'legal_unregulated', label: 'Legal' },
  { id: 'gray', label: 'Gray' },
  { id: 'restricted', label: 'Restricted' },
  { id: 'pending_ban', label: 'Pending ban' },
  { id: 'banned', label: 'Banned' },
  { id: 'recent', label: 'Changed 90d' },
];

const entries = Object.entries(US_STATE_PATHS)
  .map(([code, geom]) => {
    const state = byCode.get(code);
    return state ? { code, geom, state } : null;
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);
---
<section class="legality-map" aria-label="Interactive U.S. sweepstakes legality map">
  <div class="map-head">
    <h2>Interactive U.S. legality map</h2>
    <div class="map-filters" role="group" aria-label="Filter states by status">
      {FILTERS.map((f, i) => (
        <button type="button" class:list={['map-chip', { active: i === 0 }]} data-filter={f.id}>
          {f.label}
        </button>
      ))}
    </div>
  </div>

  <div class="map-legend" aria-hidden="true">
    {(Object.keys(SWEEPS_STATUS_META) as SweepsCasinoStatus[]).map((k) => (
      <span class="legend-item">
        <span class="legend-swatch" style={`background:${SWEEPS_STATUS_META[k].color}`}></span>
        {SWEEPS_STATUS_META[k].short}
      </span>
    ))}
  </div>

  <svg viewBox="0 0 975 610" class="map-svg" role="img" aria-label="Sweepstakes casino legal status by U.S. state">
    {entries.map(({ code, geom, state }) => {
      const recent = (now - new Date(state.sweeps_status_changed_at).getTime()) / DAY <= 90;
      return (
        <a href={`${linkBase}${state.state_slug}/`} aria-label={`${state.state_name}: ${SWEEPS_STATUS_META[state.sweeps_casino_status].label}`}>
          <path
            d={geom.d}
            data-code={code}
            data-status={state.sweeps_casino_status}
            data-recent={recent ? '1' : '0'}
            data-name={state.state_name}
            data-summary={state.sweeps_status_summary}
            style={`fill:${SWEEPS_STATUS_META[state.sweeps_casino_status].color}`}
          >
            <title>{`${state.state_name}: ${SWEEPS_STATUS_META[state.sweeps_casino_status].label}`}</title>
          </path>
        </a>
      );
    })}
  </svg>

  <p class="map-detail" data-map-detail>Hover or tap a state for its current status.</p>
</section>

<style>
  .legality-map{border:1px solid #dbe3ee;border-radius:14px;background:#fff;padding:18px 18px 14px;box-shadow:0 3px 12px rgba(10,22,40,.06);}
  .map-head{display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;}
  .map-head h2{margin:0;font-size:1.25rem;color:#0a1628;}
  .map-filters{display:flex;flex-wrap:wrap;gap:6px;}
  .map-chip{border:1px solid #cbd5e1;background:#f8fafc;color:#334155;border-radius:999px;padding:4px 12px;font-size:.8rem;cursor:pointer;line-height:1.4;}
  .map-chip:hover{border-color:#94a3b8;}
  .map-chip.active{background:#0a1628;border-color:#0a1628;color:#fff;}
  .map-legend{display:flex;flex-wrap:wrap;gap:14px;margin:12px 0 6px;font-size:.78rem;color:#475569;}
  .legend-item{display:inline-flex;align-items:center;gap:6px;}
  .legend-swatch{width:12px;height:12px;border-radius:3px;display:inline-block;border:1px solid rgba(10,22,40,.15);}
  .map-svg{width:100%;height:auto;margin-top:8px;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:10px;}
  .map-svg a{outline:none;}
  .map-svg path{stroke:#f8fafc;stroke-width:.8;cursor:pointer;transition:opacity .12s ease,stroke-width .12s ease;}
  .map-svg path:hover,.map-svg path[data-active='1']{stroke:#0a1628;stroke-width:1.6;}
  .map-svg path[data-dim='1']{opacity:.28;}
  .map-detail{margin:12px 2px 2px;font-size:.9rem;color:#334155;min-height:1.3em;}
  .map-detail strong{color:#0a1628;}
</style>

<script is:inline>
  (function () {
    var section = document.querySelector('.legality-map');
    if (!section) return;
    var paths = section.querySelectorAll('.map-svg path');
    var detail = section.querySelector('[data-map-detail]');
    var chips = section.querySelectorAll('.map-chip');

    function applyFilter(id) {
      paths.forEach(function (p) {
        var match =
          id === 'all'
            ? true
            : id === 'recent'
            ? p.getAttribute('data-recent') === '1'
            : p.getAttribute('data-status') === id;
        p.setAttribute('data-dim', match ? '0' : '1');
      });
    }

    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        chips.forEach(function (c) { c.classList.remove('active'); });
        chip.classList.add('active');
        applyFilter(chip.getAttribute('data-filter'));
      });
    });

    function showDetail(p) {
      if (!detail) return;
      while (detail.firstChild) detail.removeChild(detail.firstChild);
      var strong = document.createElement('strong');
      strong.textContent = p.getAttribute('data-name') || '';
      detail.appendChild(strong);
      var summary = p.getAttribute('data-summary');
      if (summary) detail.appendChild(document.createTextNode(' \u2014 ' + summary));
    }
    paths.forEach(function (p) {
      p.addEventListener('mouseenter', function () { showDetail(p); });
      p.addEventListener('focus', function () { showDetail(p); });
    });
  })();
</script>
